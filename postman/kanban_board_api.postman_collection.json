          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();\r",
                  "pm.environment.set(\"access_token\", data.access);\r",
                  "if (data.refresh) {\r",
                  "    pm.environment.set(\"refresh_token\", data.refresh);\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"refresh\": \"{{refresh_token}}\"\r\n}",
              "options": {
